--[[
Bulk Auto Buy/Transfer – Seeds & Gears (FINAL WORKING)
- Seeds auto-buy: "j" packets.
- Gears auto-buy: "n" packets.
- Transfer: sends seeds (category "Seeds") and gears (correct mail category from name).
  Uses same reliable SendBatch call that worked before.
]]

local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local RemoteEvent = ReplicatedStorage:WaitForChild("SharedModules"):WaitForChild("Packet"):WaitForChild("RemoteEvent")
local Networking = require(ReplicatedStorage:WaitForChild("SharedModules"):WaitForChild("Networking"))
local SendBatch = Networking.Mailbox.SendBatch

local CHECK_INTERVAL = 5

-- ================= SHOP DEFINITIONS =================
local SHOPS = {
    Seeds = {
        stockFolder = "StockValues/SeedShop/Items",
        restockPath = "StockValues/SeedShop/UnixNextRestock",
        packetPrefix = "j",
        guiLabel = "Seeds"
    },
    Gears = {
        stockFolder = "StockValues/GearShop/Items",
        restockPath = "StockValues/GearShop/UnixNextRestock",
        packetPrefix = "n",
        guiLabel = "Gears"
    }
}

-- ================= HELPERS =================
local function getStock(shopKey, itemName)
    local path = SHOPS[shopKey].stockFolder
    local folder = ReplicatedStorage
    for segment in path:gmatch("[^/]+") do
        folder = folder:FindFirstChild(segment)
        if not folder then return 0 end
    end
    local stockValue = folder:FindFirstChild(itemName)
    if stockValue then return stockValue.Value or 0 end
    return 0
end

local function getUnixNextRestock(shopKey)
    local path = SHOPS[shopKey].restockPath
    local folder = ReplicatedStorage
    for segment in path:gmatch("[^/]+") do
        folder = folder:FindFirstChild(segment)
        if not folder then return nil end
    end
    return folder.Value
end

local function getAllItemNames(shopKey)
    local names = {}
    local path = SHOPS[shopKey].stockFolder
    local folder = ReplicatedStorage
    for segment in path:gmatch("[^/]+") do
        folder = folder:FindFirstChild(segment)
        if not folder then return names end
    end
    for _, stockValue in folder:GetChildren() do
        if stockValue:IsA("IntValue") or stockValue:IsA("NumberValue") then
            table.insert(names, stockValue.Name)
        end
    end
    table.sort(names)
    return names
end

-- ================= AUTO‑BUY SYSTEM =================
local AutoBuy = {}
AutoBuy.shops = {}
for shopKey, _ in pairs(SHOPS) do
    AutoBuy.shops[shopKey] = {
        enabled = false,
        selectedItems = {},
        timerLabel = nil,
        cachedNextRestock = nil
    }
end

function AutoBuy:makeBuyBuffer(shopKey, itemName)
    local prefix = SHOPS[shopKey].packetPrefix
    return buffer.fromstring(prefix .. "\x00" .. string.char(#itemName) .. itemName)
end

function AutoBuy:buyItem(shopKey, itemName)
    RemoteEvent:FireServer(self:makeBuyBuffer(shopKey, itemName))
end

function AutoBuy:purchaseAllAvailable(shopKey)
    local shop = self.shops[shopKey]
    if not shop.enabled then return end
    if #shop.selectedItems == 0 then return end
    for _, itemName in ipairs(shop.selectedItems) do
        local stock = getStock(shopKey, itemName)
        if stock > 0 then
            print(string.format("[AutoBuy-%s] Buying %d x %s", shopKey, stock, itemName))
            for i = 1, stock do
                self:buyItem(shopKey, itemName)
                task.wait(0.05)
            end
        else
            print(string.format("[AutoBuy-%s] No stock for %s", shopKey, itemName))
        end
    end
end

function AutoBuy:restockLoop(shopKey)
    local shop = self.shops[shopKey]
    while shop.enabled do
        if not shop.cachedNextRestock then
            shop.cachedNextRestock = getUnixNextRestock(shopKey)
            if shop.cachedNextRestock then
                print(string.format("[AutoBuy-%s] Initial cached restock: %d", shopKey, shop.cachedNextRestock))
            end
        end
        local now = os.time()
        local nextRestock = shop.cachedNextRestock
        if nextRestock then
            local diff = nextRestock - now
            local sign = diff >= 0 and "+" or "-"
            print(string.format("[AutoBuy-%s] cached: %d | now: %d | diff: %s%d",
                shopKey, nextRestock, now, sign, math.abs(diff)))
        end
        if shop.timerLabel then
            if nextRestock then
                local remaining = math.max(0, nextRestock - now)
                local mins = math.floor(remaining / 60)
                local secs = remaining % 60
                shop.timerLabel.Text = string.format("%s: %dm %ds", shopKey, mins, secs)
            else
                shop.timerLabel.Text = shopKey .. ": unknown"
            end
        end
        if nextRestock and now >= nextRestock then
            print(string.format("[AutoBuy-%s] >>> Restock triggered! Buying...", shopKey))
            self:purchaseAllAvailable(shopKey)
            local newRestock = getUnixNextRestock(shopKey)
            if newRestock then
                print(string.format("[AutoBuy-%s] New restock cached: %d", shopKey, newRestock))
                shop.cachedNextRestock = newRestock
            else
                print(string.format("[AutoBuy-%s] Warning: Could not fetch new restock.", shopKey))
                shop.cachedNextRestock = nil
            end
        end
        task.wait(CHECK_INTERVAL)
    end
end

function AutoBuy:startShop(shopKey)
    local shop = self.shops[shopKey]
    if shop.enabled then return end
    shop.enabled = true
    shop.cachedNextRestock = nil
    print(string.format("[AutoBuy-%s] Started", shopKey))
    print(string.format("[AutoBuy-%s] Immediate purchase...", shopKey))
    self:purchaseAllAvailable(shopKey)
    task.spawn(function() self:restockLoop(shopKey) end)
end

function AutoBuy:stopShop(shopKey)
    local shop = self.shops[shopKey]
    shop.enabled = false
    print(string.format("[AutoBuy-%s] Stopped", shopKey))
    if shop.timerLabel then
        shop.timerLabel.Text = shopKey .. ": --"
    end
end

-- ================= TRANSFER (FIXED) =================
local Transfer = {}
Transfer.enabled = false
Transfer.targetUsername = ""
Transfer.sendInProgress = false

-- Map gear tool names to mail category (taken from MailboxItemCatalog Categories)
local function getMailCategory(tool)
    local cat = tool:GetAttribute("MainCategory")
    if not cat then return nil end
    cat = string.lower(tostring(cat))

    if cat == "seed" then
        return "Seeds"
    elseif cat == "gear" then
        local name = tool.Name
        if name:find("Sprinkler") then return "Sprinklers" end
        if name:find("Watering Can") then return "WateringCans" end
        if name:find("Mushroom") then return "Mushrooms" end
        if name:find("Gnome") then return "Gnomes" end
        if name:find("Raccoon") then return "Raccoons" end
        if name:find("Trowel") then return "Trowels" end
        -- Unknown gear – skip to avoid broken gifts
        print("[Transfer] Unknown gear type: " .. name .. " – skipping (not giftable)")
        return nil
    end
    return nil
end

function Transfer:scanInventory()
    local items = {}
    local function scanContainer(container)
        if not container then return end
        for _, tool in ipairs(container:GetChildren()) do
            if tool:IsA("Tool") then
                local mailCategory = getMailCategory(tool)
                if mailCategory then
                    local cntRaw = tool:GetAttribute("Count")
                    local cntNum = tonumber(cntRaw)
                    if cntNum and cntNum > 0 then
                        table.insert(items, {
                            Category = mailCategory,
                            ItemKey = tool.Name,
                            Count = cntNum
                        })
                    end
                end
            end
        end
    end
    scanContainer(LocalPlayer:FindFirstChild("Backpack"))
    scanContainer(LocalPlayer.Character)
    return items
end

function Transfer:sendOnce()
    if self.sendInProgress then return end
    self.sendInProgress = true

    local username = self.targetUsername
    if username == "" then
        self.sendInProgress = false
        return
    end

    local allItems = self:scanInventory()
    if #allItems == 0 then
        self.sendInProgress = false
        return
    end

    local ok, userId = pcall(function()
        return Players:GetUserIdFromNameAsync(username)
    end)
    if not ok or not userId or userId == 0 then
        self.sendInProgress = false
        return
    end

    -- Chunk into 20
    for i = 1, #allItems, 20 do
        local chunk = {}
        for j = i, math.min(i + 19, #allItems) do
            table.insert(chunk, allItems[j])
        end
        print(string.format("[Transfer] Sending batch %d-%d to %s (%d items)", i, math.min(i+19, #allItems), username, #chunk))
        local fireOk, err = pcall(function()
            SendBatch:Fire(userId, chunk, "")
        end)
        if not fireOk then
            print("[Transfer] Error: " .. tostring(err))
            break
        end
        print("[Transfer] Batch sent.")
        if i + 20 <= #allItems then
            print("[Transfer] Cooldown 10s...")
            task.wait(10)
        end
    end

    self.sendInProgress = false
end

function Transfer:loop()
    while self.enabled do
        self:sendOnce()
        task.wait(5)
    end
end

function Transfer:start()
    if self.enabled then return end
    self.enabled = true
    print("[Transfer] Auto‑send started (Seeds & Gears).")
    task.spawn(function() self:loop() end)
end

function Transfer:stop()
    self.enabled = false
    print("[Transfer] Stopped.")
end

